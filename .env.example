# ─── Supabase ────────────────────────────────────────────────────────────────
# Get from: supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── LINE LIFF ────────────────────────────────────────────────────────────────
# Get from: LINE Developers Console → Your Channel → LIFF
NEXT_PUBLIC_LIFF_ID=your-liff-id

# ─── LINE Messaging API ───────────────────────────────────────────────────────
# Get from: LINE Developers Console → Your Channel → Messaging API
LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token

# Reception group chat ID — add your bot to the group, then get the group ID
# from the webhook payload (event.source.groupId)
LINE_RECEPTION_GROUP_ID=Cxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── App ──────────────────────────────────────────────────────────────────────
# Your deployed URL (used to build the respond link sent to customers)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ─── Dev note ─────────────────────────────────────────────────────────────────
# If LINE_CHANNEL_ACCESS_TOKEN is empty, LINE messages are mocked to console.
# The app runs fully without LINE credentials — all booking logic works.
